# NexusAgent environment — copy this to .env and fill in your values
# Values in .env override docker-compose.yml defaults.

# ── Paths ────────────────────────────────────────────────────────────────────
# Absolute or relative path to your pre-built formal-conjectures checkout.
# Run `lake build` inside it once before `docker compose up`.
FORMAL_CONJECTURES_PATH=./formal-conjectures

# Directory containing parts.json, tactics_vocab.json, etc.
DATA_PATH=./data

# ── Neo4j ────────────────────────────────────────────────────────────────────
# Password for the local Neo4j container (username is always "neo4j").
NEO4J_PASSWORD=nexus_local

# Named database to use (default "neo4j" works for Community edition).
# Create a named DB in Neo4j Desktop for isolation between experiments.
NEXUS_NEO4J_DATABASE=neo4j

# ── Lean / Proof checking ────────────────────────────────────────────────────
# Controls what happens when a part uses `Decidable` / native_decide:
#   reject  — skip the part (default, safe for benchmarking)
#   allow   — ingest it anyway
NEXUS_PARTS_NATIVE_DECIDE=reject

# ── LLM providers (all optional) ─────────────────────────────────────────────
# Leave a key blank to disable that provider.

# Google Gemini
# NEXUS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# NEXUS_GEMINI_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=

# DeepSeek
# NEXUS_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_API_KEY=

# Alibaba Qwen (cloud)
# NEXUS_DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# NEXUS_QWEN_CLOUD_MODEL=qwen-plus
# DASHSCOPE_API_KEY=

# Ollama (local — use host.docker.internal to reach the host from inside Docker)
# NEXUS_OLLAMA_URL=http://host.docker.internal:11434
# NEXUS_QWEN_MODEL=qwen3.6:35b-a3b

# ── Budget guard ─────────────────────────────────────────────────────────────
# Maximum spend in USD before the agent halts (0 = unlimited)
# NEXUS_BUDGET_USD=5.00
